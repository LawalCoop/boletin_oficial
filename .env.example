# ===========================================
# DATABASE (Required)
# ===========================================
# For local Docker: postgresql://postgres:postgres@localhost:5432/boletin
# For Vercel Postgres: Get from Vercel Dashboard → Storage → Postgres
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/boletin"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/boletin"

# ===========================================
# NEXTAUTH / AUTH.JS v5 (Required)
# ===========================================
# Base URL of your app
NEXTAUTH_URL="http://localhost:3000"
# Secret for JWT encryption - generate with: openssl rand -base64 32
# Note: Auth.js v5 uses AUTH_SECRET (not NEXTAUTH_SECRET)
AUTH_SECRET="replace-with-random-string-use-openssl-rand-base64-32"

# ===========================================
# AI APIS (Required for full functionality)
# ===========================================
# Google Gemini - for document processing pipeline
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Groq - for article chat (uses Llama 3.3 70B)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=""

# ===========================================
# GOOGLE OAUTH (Required for user login + admin access)
# ===========================================
# Admin panel (/admin) is restricted to specific admin accounts
# Lawal team: Get from Bitwarden vault → "entrelinias auth cli"
# External contributors: Create at https://console.cloud.google.com/apis/credentials
#   Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
