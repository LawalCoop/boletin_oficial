# ===========================================
# DATABASE (Required)
# ===========================================
# For local Docker: postgresql://postgres:postgres@localhost:5432/boletin
# For Vercel Postgres: Get from Vercel Dashboard → Storage → Postgres
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/boletin"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/boletin"

# ===========================================
# ADMIN PANEL (Required)
# ===========================================
# Credentials for /admin panel access
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-secure-password"
ADMIN_SESSION_SECRET="replace-with-random-string-use-openssl-rand-base64-32"

# ===========================================
# NEXTAUTH (Required)
# ===========================================
# Base URL of your app
NEXTAUTH_URL="http://localhost:3000"
# Secret for JWT encryption - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-string-use-openssl-rand-base64-32"

# ===========================================
# AI APIS (Required for full functionality)
# ===========================================
# Google Gemini - for document processing pipeline
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Groq - for article chat (uses Llama 3.3 70B)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=""

# ===========================================
# GOOGLE OAUTH (Optional - for user login)
# ===========================================
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
